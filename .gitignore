### Project Specific Exclusions ###

# Data files (NPZ, CSV, Parquet, etc.)
data/processed/
data/processed_sepsis/
data/mimic-iv-3.1/
data/**/*.npz
data/**/*.csv.gz
data/**/*.parquet
data/**/*.pkl
!data/embeddings/mimic_vocab_mapped.csv # Keep mapping if small, but usually best to ignore data/ entirely

# Alternatively, just ignore everything in data except README or scripts
data/*
!data/README.md
!data/scripts/
!data/embeddings/

# Output and Checkpoints
outputs/
checkpoints/
logs/
tb_logs_sepsis/
pids/

# Result files
results/*.csv
results/*.json
results/*.jsonl
!results/README.md
results_timesfm_finetuned/
results_timesfm_sapbert_finetuned/

